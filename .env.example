# Variables de Entorno — Ejemplo de Configuración
# Copia este archivo como `.env` y llena los valores reales.
# NUNCA subas tu `.env` real a GitHub.

# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=<tu-project-id>

# ─── URL del Backend ─────────────────────────────────────────────────────────
# En local (Express corriendo): http://localhost:3000
# En Vercel (serverless functions): dejar vacío
VITE_API_BASE_URL=

# ─── Stellar / Soroban (solo para el backend/serverless) ─────────────────────
SECRET_KEY_ADMIN=S...
PUBLIC_KEY_ADMIN=G...
NFT_CONTRACT_ID=C...
PORT=3000
